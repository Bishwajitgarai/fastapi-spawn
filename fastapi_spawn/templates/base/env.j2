# Application
APP_NAME="{{ project_name }}"
ENVIRONMENT=dev
DEBUG=true
SECRET_KEY=super-secret-change-in-production
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

{% if db == "postgresql" %}
# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB={{ slug }}_db
{% endif %}
{% if db == "mysql" %}
# MySQL
MYSQL_USER=root
MYSQL_PASSWORD=mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB={{ slug }}_db
{% endif %}
{% if db == "sqlite" %}
# SQLite
SQLITE_FILE={{ slug }}.db
{% endif %}
{% if has_mongo %}
# MongoDB
MONGODB_USER=mongo
MONGODB_PASSWORD=mongo
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DB={{ slug }}_db
{% endif %}

{% if broker == "redis" or cache == "redis" or broker == "arq" or "redis" in extras or "caching" in extras or "arq" in extras %}
# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
{% endif %}
{% if broker == "rabbitmq" %}
# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
{% endif %}
{% if broker == "kafka" or "kafka" in extras %}
# Kafka
KAFKA_HOST=localhost
KAFKA_PORT=9092
{% endif %}
{% if broker == "celery" or "celery" in extras %}
# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
