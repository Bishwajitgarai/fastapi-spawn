[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "A production-ready FastAPI application"
requires-python = ">=3.10"
authors = [{ name = "Your Name", email = "you@example.com" }]
dependencies = [
    "fastapi>=0.111.0",
    "uvicorn[standard]>=0.29.0",
    "pydantic>=2.7.0",
    "pydantic-settings>=2.2.0",
    "httpx>=0.27.0",
    "slowapi>=0.1.9",             # rate limiting middleware
    "orjson>=3.9.0",              # fast JSON responses

{% if log_lib == "loguru" %}
    "loguru>=0.7.2",
{% elif log_lib == "structlog" %}
    "structlog>=24.1.0",
{% endif %}

{% if has_relational_db and orm == "sqlalchemy" %}
    "sqlalchemy[asyncio]>=2.0.0",
{% if db == "postgresql" %}
    "asyncpg>=0.29.0",
{% elif db == "mysql" %}
    "aiomysql>=0.2.0",
{% elif db == "sqlite" %}
    "aiosqlite>=0.20.0",
{% endif %}
{% endif %}
{% if has_relational_db and orm == "tortoise" %}
    "tortoise-orm>=0.21.0",
{% endif %}
{% if migration == "alembic" %}
    "alembic>=1.13.0",
{% elif migration == "aerich" %}
    "aerich>=0.7.2",
{% endif %}
{% if has_mongo and orm == "beanie" %}
    "beanie>=1.25.0",
    "motor>=3.4.0",
{% endif %}

{% if auth == "jwt" or auth == "oauth2" %}
    "python-jose[cryptography]>=3.3.0",
    "passlib[bcrypt]>=1.7.4",
    "python-multipart>=0.0.9",
{% elif auth == "api-key" %}
    "python-multipart>=0.0.9",
{% endif %}

{% if broker == "redis" or broker == "rabbitmq" %}
    "celery[redis]>=5.3.6",
{% elif broker == "kafka" %}
    "aiokafka>=0.10.0",
{% endif %}
{% if cache == "redis" or broker == "redis" %}
    "redis[hiredis]>=5.0.0",
{% elif cache == "memcached" %}
    "aiomcache>=0.8.0",
{% endif %}

{% if has_s3 %}
    "boto3>=1.34.0",
{% endif %}

{% if ai == "openai" %}
    "openai>=1.30.0",
{% elif ai == "anthropic" %}
    "anthropic>=0.28.0",
{% elif ai == "gemini" %}
    "google-generativeai>=0.7.0",
{% elif ai == "ollama" %}
    # Ollama uses httpx (already a dep above)
{% endif %}

{% if has_sentry %}
    "sentry-sdk[fastapi]>=2.0.0",
{% endif %}
{% if has_prometheus %}
    "prometheus-fastapi-instrumentator>=7.0.0",
{% endif %}

{% if email == "sendgrid" %}
    "sendgrid>=6.11.0",
{% elif email == "smtp" %}
    "fastapi-mail>=1.4.1",
{% elif email == "ses" %}
    # Uses boto3 (already included above if has_s3, else add it)
    "boto3>=1.34.0",
{% elif email == "resend" %}
    "resend>=2.1.0",
{% endif %}

{% if has_notify %}
    # httpx already included for notifications
{% endif %}

{% if vector_db == "qdrant" %}
    "qdrant-client[fastembed]>=1.9.0",
{% elif vector_db == "chroma" %}
    "chromadb>=0.5.0",
{% elif vector_db == "pinecone" %}
    "pinecone-client>=3.2.0",
{% elif vector_db == "supabase" %}
    "supabase>=2.4.0",
{% elif vector_db == "elasticsearch" %}
    "elasticsearch[async]>=8.13.0",
{% elif vector_db == "opensearch" %}
    "opensearch-py[async]>=2.5.0",
{% elif vector_db == "vespa" %}
    "pyvespa>=0.40.0",
{% endif %}

{% if has_websockets %}
    # WebSockets — built into FastAPI/starlette, no extra dep needed
{% endif %}
{% if has_graphql %}
    "strawberry-graphql[fastapi]>=0.227.0",
{% endif %}

{% if ai == "langchain" %}
    "langchain>=0.2.0",
    "langchain-openai>=0.1.0",
{% elif ai == "llamaindex" %}
    "llama-index>=0.10.0",
    "llama-index-llms-openai>=0.1.0",
    "llama-index-embeddings-openai>=0.1.0",
{% endif %}

{% if db == "duckdb" %}
    "duckdb>=0.10.0",
{% elif db == "supabase" %}
    "supabase>=2.4.0",
{% endif %}

{% if broker == "arq" %}
    "arq>=0.25.0",
    "redis[hiredis]>=5.0.0",
{% endif %}

{% if storage == "gcs" %}
    "google-cloud-storage>=2.16.0",
{% elif storage == "cloudinary" %}
    "cloudinary>=1.40.0",
{% endif %}

{% if log_dest == "cloudwatch" %}
    "watchtower>=3.3.0",
    "boto3>=1.34.0",
{% elif log_dest == "datadog" %}
    "datadog-lambda>=6.0.0",
{% endif %}

{% if extras %}
{% if "stripe" in extras %}
    "stripe>=9.0.0",
{% endif %}
{% if "sso" in extras %}
    "fastapi-sso>=0.14.0",
{% endif %}
{% if "sse" in extras %}
    "sse-starlette>=2.1.0",
{% endif %}
{% if "seed" in extras %}
    "faker>=25.0.0",
{% endif %}
{% if "ocr" in extras %}
    "pymupdf>=1.24.0",
    "pytesseract>=0.3.10",
{% endif %}
{% if "caching" in extras %}
    "fastapi-cache2[redis]>=0.2.1",
{% endif %}
{% if "meilisearch" in extras %}
    "meilisearch>=0.30.0",
{% endif %}
{% endif %}
]

[project.optional-dependencies]
dev = [
    "pytest>=8.0.0",
    "pytest-asyncio>=0.23.0",
    "pytest-cov>=5.0.0",
    "httpx>=0.27.0",
    "anyio>=4.3.0",
    "ruff>=0.4.0",
    "mypy>=1.10.0",
    "pre-commit>=3.7.0",
]

[tool.uv]
dev-dependencies = [
    "pytest>=8.0.0",
    "pytest-asyncio>=0.23.0",
    "pytest-cov>=5.0.0",
    "httpx>=0.27.0",
    "anyio>=4.3.0",
    "ruff>=0.4.0",
    "mypy>=1.10.0",
    "pre-commit>=3.7.0",
]

[tool.hatch.build.targets.wheel]
packages = ["app"]

[tool.pytest.ini_options]
asyncio_mode = "auto"
testpaths = ["tests"]
addopts = "--cov=app --cov-report=term-missing"

[tool.ruff]
line-length = 100
target-version = "py310"

[tool.ruff.lint]
select = ["E", "F", "I", "UP", "B", "SIM"]
ignore = ["E501"]

[tool.mypy]
python_version = "3.10"
strict = true
ignore_missing_imports = true
