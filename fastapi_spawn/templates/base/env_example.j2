# =============================================================================
# {{ project_name }} — Complete Environment Reference
# =============================================================================
# Generated by fastapi-spawn v0.3.0 — https://pypi.org/project/fastapi-spawn/
# Copy to .env and fill real values. NEVER commit .env to version control.
# Sections marked (active) are wired in your current config.
# All others are commented — uncomment when you add those integrations.
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="{{ project_name }}"
ENVIRONMENT=dev                      # dev | staging | production
API_V1_PREFIX=/api/v1
SECRET_KEY=CHANGE_ME                 # openssl rand -hex 32
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_DIR=logs
LOG_BACKUP_DAYS=30

# =============================================================================
# DATABASE
# =============================================================================
{% if db == "postgresql" %}
# PostgreSQL (active) — assembled in code as postgresql+asyncpg://...
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB={{ slug }}_db
{% elif db == "mysql" %}
# MySQL (active) — assembled in code as mysql+aiomysql://...
MYSQL_USER=root
MYSQL_PASSWORD=CHANGE_ME
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB={{ slug }}_db
{% elif db == "sqlite" %}
# SQLite (active)
SQLITE_FILE={{ slug }}.db
{% elif db == "supabase" %}
# Supabase (active) — managed Postgres + realtime + vector
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=CHANGE_ME               # anon or service role key
{% elif db == "duckdb" %}
# DuckDB (active) — analytical / OLAP
DUCKDB_FILE={{ slug }}.duckdb
{% endif %}
{% if has_mongo %}
# MongoDB (active) — assembled in code as mongodb://...
MONGODB_USER=mongo
MONGODB_PASSWORD=CHANGE_ME
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DB={{ slug }}_db
{% endif %}

# Other databases — uncomment when needed:
# POSTGRES_USER=postgres | POSTGRES_PASSWORD=... | POSTGRES_HOST=localhost | POSTGRES_PORT=5432 | POSTGRES_DB={{ slug }}_db
# MYSQL_USER=root | MYSQL_PASSWORD=... | MYSQL_HOST=localhost | MYSQL_PORT=3306 | MYSQL_DB={{ slug }}_db
# SUPABASE_URL=https://xxxx.supabase.co | SUPABASE_KEY=...
# DUCKDB_FILE={{ slug }}.duckdb

# =============================================================================
# CACHE & MESSAGING
# =============================================================================
{% if broker == "redis" or cache == "redis" or broker == "arq" or "caching" in extras or "redis" in extras or "arq" in extras %}
# Redis (active) — assembled in code as redis://:PASS@HOST:PORT/DB
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
{% else %}
# Redis — uncomment if adding cache, Celery, or Arq:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
{% endif %}

{% if broker == "rabbitmq" %}
# RabbitMQ (active) — assembled in code as amqp://...
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=CHANGE_ME
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
{% endif %}

{% if broker == "kafka" or "kafka" in extras %}
# Kafka (active)
KAFKA_HOST=localhost
KAFKA_PORT=9092
{% endif %}

{% if broker == "celery" or "celery" in extras %}
# Celery (active)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
{% endif %}

# =============================================================================
# AUTH & SECURITY
# =============================================================================
{% if has_auth or auth != "none" or "auth" in extras %}
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
{% if auth == "auth0" or "auth0" in extras %}
# Auth0 (active)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=CHANGE_ME
AUTH0_CLIENT_SECRET=CHANGE_ME
AUTH0_AUDIENCE=https://your-api.example.com
{% endif %}
{% else %}
# JWT Auth — uncomment when adding --auth jwt:
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7
# ALGORITHM=HS256
#
# Auth0 — uncomment when adding --auth auth0:
# AUTH0_DOMAIN=your-tenant.auth0.com
# AUTH0_CLIENT_ID=CHANGE_ME
# AUTH0_CLIENT_SECRET=CHANGE_ME
# AUTH0_AUDIENCE=https://your-api.example.com
{% endif %}

# =============================================================================
# STORAGE
# =============================================================================
{% if storage == "s3" or has_s3 or "s3" in extras %}
# AWS S3 / MinIO (active)
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=us-east-1
AWS_S3_BUCKET={{ slug }}-bucket
AWS_S3_ENDPOINT_URL=               # http://localhost:9000 for MinIO (local S3)
{% elif storage == "gcs" or "gcs" in extras %}
# Google Cloud Storage (active)
GCS_PROJECT_ID=CHANGE_ME
GCS_BUCKET={{ slug }}-bucket
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
{% elif storage == "cloudinary" or "cloudinary" in extras %}
# Cloudinary (active)
CLOUDINARY_CLOUD_NAME=CHANGE_ME
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME
{% else %}
# Storage — uncomment the provider you need:
# AWS S3 / MinIO: AWS_ACCESS_KEY_ID | AWS_SECRET_ACCESS_KEY | AWS_REGION | AWS_S3_BUCKET | AWS_S3_ENDPOINT_URL
# GCS: GCS_PROJECT_ID | GCS_BUCKET | GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# Cloudinary: CLOUDINARY_CLOUD_NAME | CLOUDINARY_API_KEY | CLOUDINARY_API_SECRET
{% endif %}

# Also used for SES / CloudWatch (if needed):
# AWS_ACCESS_KEY_ID=CHANGE_ME
# AWS_SECRET_ACCESS_KEY=CHANGE_ME
# AWS_REGION=us-east-1

# =============================================================================
# AI / LLM
# =============================================================================
{% if ai == "openai" or "openai" in extras %}
# OpenAI (active)
OPENAI_API_KEY=sk-placeholder
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=                   # blank = api.openai.com
                                   # Azure: https://<resource>.openai.azure.com/
                                   # LM Studio / Ollama: http://localhost:1234/v1
{% elif ai == "anthropic" or "anthropic" in extras %}
# Anthropic Claude (active)
ANTHROPIC_API_KEY=sk-ant-placeholder
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
{% elif ai == "gemini" or "gemini" in extras %}
# Google Gemini (active)
GEMINI_API_KEY=CHANGE_ME
GEMINI_MODEL=gemini-1.5-pro
{% elif ai == "ollama" or "ollama" in extras %}
# Ollama — local LLM, no API key (active)
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3
{% elif ai == "langchain" or "langchain" in extras %}
# LangChain (active) — uses OpenAI backend by default
OPENAI_API_KEY=sk-placeholder
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=
{% elif ai == "llamaindex" or "llamaindex" in extras %}
# LlamaIndex (active) — uses OpenAI backend by default
OPENAI_API_KEY=sk-placeholder
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=
{% else %}
# AI / LLM — uncomment the provider you need:
# OpenAI:     OPENAI_API_KEY=sk-placeholder | OPENAI_MODEL=gpt-4o | OPENAI_EMBEDDING_MODEL=text-embedding-3-small | OPENAI_BASE_URL=
# Anthropic:  ANTHROPIC_API_KEY=sk-ant-placeholder | ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# Gemini:     GEMINI_API_KEY=CHANGE_ME | GEMINI_MODEL=gemini-1.5-pro
# Ollama:     OLLAMA_HOST=localhost | OLLAMA_PORT=11434 | OLLAMA_MODEL=llama3  (no API key)
# LangChain:  uses OPENAI_* vars above
# LlamaIndex: uses OPENAI_* vars above
{% endif %}

# =============================================================================
# MONITORING
# =============================================================================
{% if has_sentry or "sentry" in extras %}
# Sentry (active)
SENTRY_DSN=https://xxx@sentry.io/yyy
{% else %}
# Sentry — uncomment to enable:
# SENTRY_DSN=https://xxx@sentry.io/yyy
{% endif %}
# Prometheus metrics: exposed at /metrics — no config needed
# OpenTelemetry: configure OTEL_EXPORTER_OTLP_ENDPOINT in your container

# =============================================================================
# EMAIL
# =============================================================================
{% if email == "sendgrid" or "sendgrid" in extras %}
# SendGrid (active)
SENDGRID_API_KEY=SG.placeholder
SENDGRID_FROM_EMAIL=noreply@example.com
{% elif email == "smtp" or "smtp" in extras %}
# SMTP (active)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM_EMAIL=noreply@example.com
SMTP_STARTTLS=true
SMTP_SSL=false
{% elif email == "ses" or "ses" in extras %}
# AWS SES (active) — uses AWS_* credentials above
SES_FROM_EMAIL=noreply@example.com
{% elif email == "resend" or "resend" in extras %}
# Resend (active)
RESEND_API_KEY=re_placeholder
RESEND_FROM_EMAIL=noreply@example.com
{% else %}
# Email — uncomment the provider you need:
# SendGrid: SENDGRID_API_KEY=SG.placeholder | SENDGRID_FROM_EMAIL=noreply@example.com
# SMTP:     SMTP_HOST=smtp.gmail.com | SMTP_PORT=587 | SMTP_USER=... | SMTP_PASSWORD=... | SMTP_FROM_EMAIL=... | SMTP_STARTTLS=true | SMTP_SSL=false
# AWS SES:  SES_FROM_EMAIL=noreply@example.com  (uses AWS_* credentials)
# Resend:   RESEND_API_KEY=re_placeholder | RESEND_FROM_EMAIL=noreply@example.com
{% endif %}

# =============================================================================
# NOTIFICATIONS
# =============================================================================
{% if notify == "slack" or "slack" in extras %}
# Slack (active)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE_ME
{% elif notify == "discord" or "discord" in extras %}
# Discord (active)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/CHANGE_ME
{% else %}
# Notifications — uncomment the provider you need:
# Slack:   SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE_ME
# Discord: DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/CHANGE_ME
{% endif %}

# =============================================================================
# VECTOR DATABASE
# =============================================================================
{% if vector_db == "qdrant" or "qdrant" in extras %}
# Qdrant (active)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=                    # blank for local Docker Qdrant
{% elif vector_db == "chroma" or "chroma" in extras %}
# ChromaDB (active) — local persistent, no server needed
# CHROMA_DATA_PATH=./chroma_data   # configured in code
{% elif vector_db == "pinecone" or "pinecone" in extras %}
# Pinecone (active)
PINECONE_API_KEY=CHANGE_ME
PINECONE_INDEX_NAME={{ slug }}-index
{% elif vector_db == "supabase" or "supabase" in extras %}
# Supabase pgvector (active) — uses SUPABASE_URL / SUPABASE_KEY above
{% elif vector_db == "elasticsearch" or "elasticsearch" in extras %}
# Elasticsearch (active)
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_API_KEY=
{% elif vector_db == "opensearch" or "opensearch" in extras %}
# OpenSearch (active)
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin
{% elif vector_db == "vespa" or "vespa" in extras %}
# Vespa (active)
VESPA_ENDPOINT=http://localhost:8080
{% else %}
# Vector DB — uncomment the provider you need:
# Qdrant:        QDRANT_HOST=localhost | QDRANT_PORT=6333 | QDRANT_API_KEY=  (blank for local)
# ChromaDB:      local only — no env vars needed
# Pinecone:      PINECONE_API_KEY=CHANGE_ME | PINECONE_INDEX_NAME={{ slug }}-index
# Supabase:      uses SUPABASE_URL / SUPABASE_KEY above
# Elasticsearch: ELASTICSEARCH_HOST=localhost | ELASTICSEARCH_PORT=9200 | ELASTICSEARCH_API_KEY=
# OpenSearch:    OPENSEARCH_HOST=localhost | OPENSEARCH_PORT=9200 | OPENSEARCH_USER=admin | OPENSEARCH_PASSWORD=admin
# Vespa:         VESPA_ENDPOINT=http://localhost:8080
{% endif %}

# =============================================================================
# LOG DESTINATION
# =============================================================================
{% if log_dest == "cloudwatch" %}
# AWS CloudWatch Logs (active) — uses AWS_* credentials above
# Log group: /{{ slug }}/${ENVIRONMENT}
{% elif log_dest == "datadog" %}
# Datadog (active)
DD_API_KEY=CHANGE_ME
DD_SITE=datadoghq.com
{% else %}
# Remote logging — uncomment to enable:
# CloudWatch: uses AWS_* credentials — no extra vars needed
# Datadog:    DD_API_KEY=CHANGE_ME | DD_SITE=datadoghq.com
# OpenTelemetry: OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317  (set in compose)
{% endif %}

# =============================================================================
# EXTRAS (Payments, SSO, Search)
# =============================================================================
{% if extras %}
{% if "stripe" in extras %}
# Stripe (active)
STRIPE_API_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
{% endif %}
{% if "sso" in extras or "sso-google" in extras or "sso-github" in extras or "sso-microsoft" in extras %}
# SSO - Google, GitHub, Microsoft (active)
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder
GITHUB_CLIENT_ID=placeholder
GITHUB_CLIENT_SECRET=placeholder
MICROSOFT_CLIENT_ID=placeholder
MICROSOFT_CLIENT_SECRET=placeholder
MICROSOFT_TENANT_ID=placeholder
{% endif %}
{% if "meilisearch" in extras %}
# Meilisearch (active)
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=masterKey
{% endif %}
{% if "opensearch" in extras %}
# OpenSearch (active)
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin
{% endif %}
{% if "vespa" in extras %}
# Vespa (active)
VESPA_ENDPOINT=http://localhost:8080
{% endif %}
{% endif %}
