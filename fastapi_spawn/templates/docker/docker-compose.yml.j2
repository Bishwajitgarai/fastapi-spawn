services:
  app:
    build: .
    ports:
      - "8000:8000"
    env_file:
      - .env
{% if (has_relational_db and db != "sqlite") or has_mongo or broker == "redis" or cache == "redis" or broker == "rabbitmq" %}
    depends_on:
{% if has_relational_db and db == "postgresql" %}
      - postgres
{% endif %}
{% if has_relational_db and db == "mysql" %}
      - mysql
{% endif %}
{% if has_mongo %}
      - mongodb
{% endif %}
{% if broker == "redis" or cache == "redis" %}
      - redis
{% endif %}
{% if broker == "rabbitmq" %}
      - rabbitmq
{% endif %}
{% endif %}
    volumes:
      - .:/app
{% if (has_relational_db and db != "sqlite") or has_mongo or broker == "redis" or cache == "redis" or broker == "rabbitmq" %}
    environment:
{% if has_relational_db and db == "postgresql" %}
      - POSTGRES_HOST=postgres
{% endif %}
{% if has_relational_db and db == "mysql" %}
      - MYSQL_HOST=mysql
{% endif %}
{% if has_mongo %}
      - MONGODB_HOST=mongodb
{% endif %}
{% if broker == "redis" or cache == "redis" %}
      - REDIS_HOST=redis
{% endif %}
{% if broker == "rabbitmq" %}
      - RABBITMQ_HOST=rabbitmq
{% endif %}
{% endif %}
    restart: unless-stopped

{% if has_broker and broker != "kafka" %}
  worker:
    build: .
    command: celery -A tasks.celery_app worker --loglevel=info --concurrency=2
    env_file:
      - .env
    depends_on:
      - app
    environment:
{% if has_relational_db and db == "postgresql" %}
      - POSTGRES_HOST=postgres
{% endif %}
{% if has_relational_db and db == "mysql" %}
      - MYSQL_HOST=mysql
{% endif %}
{% if broker == "redis" or cache == "redis" %}
      - REDIS_HOST=redis
{% endif %}
{% if broker == "rabbitmq" %}
      - RABBITMQ_HOST=rabbitmq
{% endif %}
    restart: unless-stopped
{% endif %}

{% if has_relational_db and db == "postgresql" %}
  postgres:
    image: postgres:16-alpine
    environment:
      POSTGRES_DB: {{ slug }}_db
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres -d {{ slug }}_db"]
      interval: 10s
      timeout: 5s
      retries: 5
{% endif %}

{% if has_relational_db and db == "mysql" %}
  mysql:
    image: mysql:8
    environment:
      MYSQL_DATABASE: {{ slug }}_db
      MYSQL_ROOT_PASSWORD: mysql
    ports:
      - "3306:3306"
    volumes:
      - mysql_data:/var/lib/mysql
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 10s
      timeout: 5s
      retries: 5
{% endif %}

{% if has_mongo %}
  mongodb:
    image: mongo:7
    ports:
      - "27017:27017"
    environment:
      - MONGO_INITDB_ROOT_USERNAME=mongo
      - MONGO_INITDB_ROOT_PASSWORD=mongo
    volumes:
      - mongo_data:/data/db
    healthcheck:
      test: ["CMD-SHELL", "mongosh --eval 'db.runCommand({ping: 1})' --quiet"]
      interval: 10s
      timeout: 5s
      retries: 5
{% endif %}

{% if broker == "redis" or cache == "redis" %}
  redis:
    image: redis:7-alpine
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 3s
      retries: 3
{% endif %}

{% if broker == "rabbitmq" %}
  rabbitmq:
    image: rabbitmq:3-management-alpine
    ports:
      - "5672:5672"
      - "15672:15672"
    environment:
      RABBITMQ_DEFAULT_USER: guest
      RABBITMQ_DEFAULT_PASS: guest
    healthcheck:
      test: ["CMD", "rabbitmq-diagnostics", "-q", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
{% endif %}

{% if vector_db == "qdrant" %}
  qdrant:
    image: qdrant/qdrant:latest
    ports:
      - "6333:6333"
    volumes:
      - qdrant_data:/qdrant/storage
{% endif %}

{% if vector_db == "elasticsearch" %}
  elasticsearch:
    image: docker.elastic.co/elasticsearch/elasticsearch:8.12.0
    environment:
      - discovery.type=single-node
      - xpack.security.enabled=false
      - "ES_JAVA_OPTS=-Xms512m -Xmx512m"
    ports:
      - "9200:9200"
    volumes:
      - es_data:/usr/share/elasticsearch/data
{% endif %}

{% if vector_db == "opensearch" %}
  opensearch:
    image: opensearchproject/opensearch:2.11.0
    environment:
      - discovery.type=single-node
      - plugins.security.disabled=true
      - OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
    ports:
      - "9200:9200"
    volumes:
      - opensearch_data:/usr/share/opensearch/data
{% endif %}

{% if ai == "ollama" %}
  ollama:
    image: ollama/ollama:latest
    ports:
      - "11434:11434"
    volumes:
      - ollama_data:/root/.ollama
{% endif %}

{% if (has_relational_db and db != "sqlite") or has_mongo or broker == "redis" or cache == "redis" or vector_db == "qdrant" or vector_db == "elasticsearch" or vector_db == "opensearch" or ai == "ollama" %}
volumes:
{% if has_relational_db and db == "postgresql" %}
  postgres_data:
{% endif %}
{% if has_relational_db and db == "mysql" %}
  mysql_data:
{% endif %}
{% if has_mongo %}
  mongo_data:
{% endif %}
{% if broker == "redis" or cache == "redis" %}
  redis_data:
{% endif %}
{% if vector_db == "qdrant" %}
  qdrant_data:
{% endif %}
{% if vector_db == "elasticsearch" %}
  es_data:
{% endif %}
{% if vector_db == "opensearch" %}
  opensearch_data:
{% endif %}
{% if ai == "ollama" %}
  ollama_data:
{% endif %}
{% endif %}
