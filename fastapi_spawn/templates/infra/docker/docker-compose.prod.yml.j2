apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ slug }}
  labels:
    app: {{ slug }}
spec:
  replicas: 2
  selector:
    matchLabels:
      app: {{ slug }}
  template:
    metadata:
      labels:
        app: {{ slug }}
    spec:
      containers:
        - name: {{ slug }}
          image: ghcr.io/your-org/{{ slug }}:latest
          ports:
            - containerPort: 8000
          envFrom:
            - secretRef:
                name: {{ slug }}-secrets
          livenessProbe:
            httpGet:
              path: /api/v1/health/liveness
              port: 8000
            initialDelaySeconds: 15
            periodSeconds: 20
          readinessProbe:
            httpGet:
              path: /api/v1/health/readiness
              port: 8000
            initialDelaySeconds: 5
            periodSeconds: 10
          resources:
            requests:
              memory: "128Mi"
              cpu: "100m"
            limits:
              memory: "512Mi"
              cpu: "500m"
