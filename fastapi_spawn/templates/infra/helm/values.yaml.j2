replicaCount: 2

image:
  repository: ghcr.io/your-org/{{ slug }}
  tag: latest
  pullPolicy: IfNotPresent

service:
  type: ClusterIP
  port: 8000

ingress:
  enabled: false
  host: {{ slug }}.example.com

env:
  APP_ENV: production
  DEBUG: "false"

resources:
  requests:
    memory: "128Mi"
    cpu: "100m"
  limits:
    memory: "512Mi"
    cpu: "500m"
