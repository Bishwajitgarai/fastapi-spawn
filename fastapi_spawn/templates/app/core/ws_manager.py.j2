"""WebSocket connection manager for {{ project_name }}."""

from __future__ import annotations

import uuid
from typing import Any

from fastapi import WebSocket


class ConnectionManager:
    """
    Manages active WebSocket connections with broadcast and targeted messaging.

    Usage:
        manager = ConnectionManager()
        await manager.connect(websocket, client_id="user-123")
        await manager.broadcast({"type": "ping", "data": "hello"})
        manager.disconnect(websocket)
    """

    def __init__(self) -> None:
        # Maps client_id → WebSocket
        self._connections: dict[str, WebSocket] = {}

    @property
    def connected_count(self) -> int:
        return len(self._connections)

    async def connect(self, websocket: WebSocket, client_id: str | None = None) -> str:
        """Accept the connection and register it. Returns the assigned client_id."""
        await websocket.accept()
        cid = client_id or str(uuid.uuid4())
        self._connections[cid] = websocket
        return cid

    def disconnect(self, websocket: WebSocket) -> str | None:
        """Remove a connection by WebSocket instance. Returns its client_id."""
        cid = next((k for k, v in self._connections.items() if v is websocket), None)
        if cid:
            del self._connections[cid]
        return cid

    async def send_personal(self, message: Any, client_id: str) -> bool:
        """Send a message to a specific client. Returns False if not connected."""
        ws = self._connections.get(client_id)
        if not ws:
            return False
        if isinstance(message, (dict, list)):
            await ws.send_json(message)
        else:
            await ws.send_text(str(message))
        return True

    async def broadcast(self, message: Any) -> None:
        """Broadcast a message to all connected clients."""
        dead: list[str] = []
        for cid, ws in self._connections.items():
            try:
                if isinstance(message, (dict, list)):
                    await ws.send_json(message)
                else:
                    await ws.send_text(str(message))
            except Exception:
                dead.append(cid)
        for cid in dead:
            self._connections.pop(cid, None)

    def get_client_ids(self) -> list[str]:
        return list(self._connections.keys())


# ── Singleton instance (import in your router) ─────────────────────────────
manager = ConnectionManager()
