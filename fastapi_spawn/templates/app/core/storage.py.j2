"""File storage utilities for {{ project_name }}."""

from __future__ import annotations

{% if storage == "s3" %}
import boto3
from botocore.exceptions import ClientError

from app.core.config import settings


def _client():
    kwargs = {
        "region_name": settings.AWS_REGION,
        "aws_access_key_id": settings.AWS_ACCESS_KEY_ID,
        "aws_secret_access_key": settings.AWS_SECRET_ACCESS_KEY,
    }
    if settings.AWS_S3_ENDPOINT_URL:
        kwargs["endpoint_url"] = settings.AWS_S3_ENDPOINT_URL  # MinIO / LocalStack
    return boto3.client("s3", **kwargs)


def upload_file(file_path: str, object_key: str, bucket: str | None = None) -> str:
    bucket = bucket or settings.AWS_S3_BUCKET
    _client().upload_file(file_path, bucket, object_key)
    return object_key


def upload_fileobj(file_obj, object_key: str, bucket: str | None = None, content_type: str = "application/octet-stream") -> str:
    bucket = bucket or settings.AWS_S3_BUCKET
    _client().upload_fileobj(file_obj, bucket, object_key, ExtraArgs={"ContentType": content_type})
    return object_key


def generate_presigned_url(object_key: str, expires_in: int = 3600, bucket: str | None = None) -> str:
    bucket = bucket or settings.AWS_S3_BUCKET
    return _client().generate_presigned_url("get_object", Params={"Bucket": bucket, "Key": object_key}, ExpiresIn=expires_in)


def delete_file(object_key: str, bucket: str | None = None) -> None:
    _client().delete_object(Bucket=bucket or settings.AWS_S3_BUCKET, Key=object_key)


def file_exists(object_key: str, bucket: str | None = None) -> bool:
    try:
        _client().head_object(Bucket=bucket or settings.AWS_S3_BUCKET, Key=object_key)
        return True
    except ClientError:
        return False

{% elif storage == "gcs" %}
from google.cloud import storage as gcs_lib
from functools import lru_cache

from app.core.config import settings


@lru_cache
def _client() -> gcs_lib.Client:
    """Return a cached GCS client. Uses GOOGLE_APPLICATION_CREDENTIALS env or ADC."""
    return gcs_lib.Client(project=settings.GCS_PROJECT_ID)


def upload_file(file_path: str, object_key: str, bucket: str | None = None) -> str:
    b = _client().bucket(bucket or settings.GCS_BUCKET)
    blob = b.blob(object_key)
    blob.upload_from_filename(file_path)
    return object_key


def upload_fileobj(file_obj, object_key: str, bucket: str | None = None, content_type: str = "application/octet-stream") -> str:
    b = _client().bucket(bucket or settings.GCS_BUCKET)
    blob = b.blob(object_key)
    blob.upload_from_file(file_obj, content_type=content_type)
    return object_key


def generate_presigned_url(object_key: str, expires_in: int = 3600, bucket: str | None = None) -> str:
    from datetime import timedelta
    b = _client().bucket(bucket or settings.GCS_BUCKET)
    return b.blob(object_key).generate_signed_url(expiration=timedelta(seconds=expires_in), method="GET")


def delete_file(object_key: str, bucket: str | None = None) -> None:
    _client().bucket(bucket or settings.GCS_BUCKET).blob(object_key).delete()

{% elif storage == "cloudinary" %}
import cloudinary
import cloudinary.uploader
import cloudinary.api

from app.core.config import settings

cloudinary.config(
    cloud_name=settings.CLOUDINARY_CLOUD_NAME,
    api_key=settings.CLOUDINARY_API_KEY,
    api_secret=settings.CLOUDINARY_API_SECRET,
    secure=True,
)


def upload_image(file_path: str, public_id: str | None = None, folder: str = "{{ slug }}") -> dict:
    """Upload an image/video to Cloudinary. Returns the full response dict."""
    return cloudinary.uploader.upload(
        file_path,
        public_id=public_id,
        folder=folder,
        overwrite=True,
    )


def get_optimized_url(public_id: str, width: int = 800, quality: str = "auto") -> str:
    """Return an auto-optimized CDN URL."""
    from cloudinary import CloudinaryImage
    return CloudinaryImage(public_id).build_url(width=width, quality=quality, fetch_format="auto")


def delete_file(public_id: str) -> dict:
    return cloudinary.uploader.destroy(public_id)

{% endif %}
