"""Notification helpers for {{ project_name }}."""

from __future__ import annotations

import httpx

from app.core.config import settings

{% if notify == "slack" %}
async def send_slack(text: str, channel: str | None = None) -> bool:
    """
    Send a message to a Slack channel via an incoming webhook.
    Set SLACK_WEBHOOK_URL in .env.
    """
    payload: dict = {"text": text}
    if channel:
        payload["channel"] = channel

    async with httpx.AsyncClient() as client:
        response = await client.post(
            settings.SLACK_WEBHOOK_URL,
            json=payload,
            timeout=10,
        )
    return response.status_code == 200


async def send_slack_alert(title: str, message: str, color: str = "#ff0000") -> bool:
    """Send a formatted Slack alert with attachment."""
    payload = {
        "attachments": [
            {
                "color": color,
                "title": title,
                "text": message,
                "footer": "{{ project_name }}",
            }
        ]
    }
    async with httpx.AsyncClient() as client:
        response = await client.post(settings.SLACK_WEBHOOK_URL, json=payload, timeout=10)
    return response.status_code == 200

{% elif notify == "discord" %}
async def send_discord(content: str, username: str = "{{ project_name }}") -> bool:
    """
    Send a message to a Discord channel via a webhook.
    Set DISCORD_WEBHOOK_URL in .env.
    """
    payload = {"content": content, "username": username}
    async with httpx.AsyncClient() as client:
        response = await client.post(
            settings.DISCORD_WEBHOOK_URL,
            json=payload,
            timeout=10,
        )
    return response.status_code in (200, 204)


async def send_discord_embed(title: str, description: str, color: int = 0xFF0000) -> bool:
    """Send a formatted Discord embed."""
    payload = {
        "username": "{{ project_name }}",
        "embeds": [{"title": title, "description": description, "color": color}],
    }
    async with httpx.AsyncClient() as client:
        response = await client.post(settings.DISCORD_WEBHOOK_URL, json=payload, timeout=10)
    return response.status_code in (200, 204)

{% endif %}
